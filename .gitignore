# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# media-box local config (dev database, logs)
.config-dev/

# IDE
.idea/
.vscode/

# local agent/CI leftovers (repo is hosted on GitHub; Gitea workflow kept for reference)
.codex/
.gitea/

# graphify analysis output
/graphify-out/

# MCP server (zero-dep; ignore deps if any are ever added, and local overrides)
/mcp/node_modules/
.mcp.local.json
